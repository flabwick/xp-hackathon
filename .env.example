AI_PROVIDER=gemini
GEMINI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here

# Auth
# Must be at least 32 characters. Generate with: openssl rand -hex 48
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# Email (verification codes). If RESEND_API_KEY is empty, codes are printed to stdout.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
